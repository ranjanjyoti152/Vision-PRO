# ============================================
# Vision Pro Dezine – Environment Configuration
# ============================================
# ONLY connection strings go here.
# All service credentials (Telegram, WhatsApp, LLM APIs)
# are configured via the UI and stored encrypted in MongoDB.
# ============================================

# --- MongoDB ---
MONGO_HOST=localhost
MONGO_PORT=27917
MONGO_USER=visionpro
MONGO_PASS=visionpro_secret
MONGO_DB=visionpro

# --- Qdrant Vector DB ---
QDRANT_HOST=localhost
QDRANT_PORT=6933
QDRANT_GRPC_PORT=6934

# --- Backend ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
SECRET_KEY=change-this-to-a-random-secret-key
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# --- Frontend ---
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000

# --- Storage ---
RECORDING_PATH=./recordings
MODELS_PATH=./models

# --- DeepStream (GPU Pipeline) ---
# DEEPSTREAM_ENABLED=True          # Uncomment to use DeepStream instead of OpenCV
# DS_CONF_THRESHOLD=0.45

# --- Jetson Configuration ---
# Uncomment these when deploying on NVIDIA Jetson (JetPack 6.0)
# JETSON_MODE=true
# TRT_WORKSPACE_GB=2               # TRT builder workspace (2GB default for Jetson)
# ONNX_MODEL_PATH=./models/onnx/yolov8n.onnx
# STREAM_MAX_FPS=15                # Lower FPS for Jetson thermal budget
